# Flow Learn Production Environment Variables
# Copy to .env and fill in all values before deployment

# === REQUIRED ===

# Domain configuration
DOMAIN=yourdomain.com
FRONTEND_HOST=https://dashboard.yourdomain.com
SERVER_HOST=https://api.yourdomain.com
STACK_NAME=dream-lms

# Security (MUST change from defaults)
SECRET_KEY=  # Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
FIRST_SUPERUSER=admin@yourdomain.com
FIRST_SUPERUSER_PASSWORD=  # Strong password

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=  # Strong password
POSTGRES_DB=app
POSTGRES_SERVER=pgbouncer
POSTGRES_PORT=6432

# Dream Central Storage
DREAM_CENTRAL_STORAGE_URL=https://dcs.yourdomain.com
DREAM_CENTRAL_STORAGE_API_KEY=  # Your DCS API key
DREAM_CENTRAL_STORAGE_WEBHOOK_SECRET=  # Min 16 characters

# === AI PROVIDERS (at least one required) ===
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# === OPTIONAL ===

# Environment
ENVIRONMENT=production
PROJECT_NAME=Flow Learn

# CORS (comma-separated production domains)
BACKEND_CORS_ORIGINS=https://dashboard.yourdomain.com

# Redis
REDIS_URL=redis://redis:6380/0
RATE_LIMIT_REDIS_URL=redis://redis:6380/1
REDIS_MAXMEMORY=256mb

# Docker images
DOCKER_IMAGE_BACKEND=flow-learn-backend
DOCKER_IMAGE_FRONTEND=flow-learn-frontend
TAG=latest

# AI Quota
AI_MONTHLY_QUOTA=100

# Monitoring
SENTRY_DSN=

# === PERFORMANCE TUNING (defaults for Hetzner CX43: 8 vCPU, 16GB) ===

# Backend DB pool (through PGBouncer)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=10
DB_POOL_RECYCLE=300

# Worker DB pool (lighter — background tasks)
WORKER_DB_POOL_SIZE=5
WORKER_DB_MAX_OVERFLOW=5

# DCS HTTP client connections
DCS_MAX_CONNECTIONS=20
DCS_MAX_KEEPALIVE=10

# PostgreSQL tuning
PG_MAX_CONNECTIONS=220
PG_SHARED_BUFFERS=512MB
PG_EFFECTIVE_CACHE=2GB
PG_WORK_MEM=8MB
PG_MAINT_WORK_MEM=128MB
PG_STATEMENT_TIMEOUT=30000
