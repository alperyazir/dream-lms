# Application
APP_NAME=Dream LMS API
APP_VERSION=0.1.0

# Database
# Async driver for SQLAlchemy operations (asyncpg)
DATABASE_URL=postgresql+asyncpg://dream_user:dream_pass@postgres:5432/dream_lms
# Sync driver for Alembic migrations (psycopg)
ALEMBIC_DATABASE_URL=postgresql+psycopg://dream_user:dream_pass@postgres:5432/dream_lms

# JWT Authentication (Story 1.3)
# Generate a secure random key: openssl rand -hex 32
JWT_SECRET_KEY=change_this_to_a_random_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# Dream Central Storage Integration (Story 2.1)
# URL of the Dream Central Storage API
DREAM_STORAGE_API_URL=http://localhost:8000
# Admin credentials for Dream Central Storage
DREAM_STORAGE_ADMIN_EMAIL=admin@dreamcentral.com
DREAM_STORAGE_ADMIN_PASSWORD=secure_password_here
