# Domain
# This would be set to the production domain with an env var on deployment
# used by Traefik to transmit traffic and acquire TLS certificates
DOMAIN=localhost
# To test the local Traefik config
# DOMAIN=localhost.tiangolo.com

FRONTEND_HOST=http://localhost:5173
# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Full Stack FastAPI Project"
STACK_NAME=full-stack-fastapi-project

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173,http://localhost.tiangolo.com"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_PASSWORD=changethis

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

SENTRY_DSN=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# Dream Central Storage API Integration
# ⚠️  SECURITY WARNING: Development credentials only! MUST be changed for production!
# ⚠️  Never commit production credentials to version control!
# ⚠️  Use secure secrets management (AWS Secrets Manager, vault, etc.) in production
DREAM_CENTRAL_STORAGE_URL=http://localhost:8081
DREAM_CENTRAL_STORAGE_PASSWORD=admin
DREAM_CENTRAL_STORAGE_TOKEN_EXPIRY=1800  # JWT token expiry in seconds (default: 30 minutes)
DREAM_CENTRAL_STORAGE_WEBHOOK_SECRET=changethis  # Secret for validating webhook signatures from Dream Central Storage

# Server Host for Webhook Callbacks
# This is the URL that external services (like DCS) will use to send webhooks to this LMS
# 🔧 Local Development (Docker): Use host.docker.internal to allow DCS container to reach LMS
# 🚀 Production (Same Network): Use internal service name (e.g., http://backend:8000)
# 🌐 Production (Different Machines): Use actual domain or IP (e.g., https://lms.example.com)
SERVER_HOST=http://host.docker.internal:8000

# DCS Cache Configuration (optional - uses defaults if not specified)
# DCS_CACHE_DEFAULT_TTL=300  # Default cache TTL: 5 minutes
# DCS_CACHE_PUBLISHER_TTL=600  # Publisher cache TTL: 10 minutes
# DCS_CACHE_BOOK_TTL=600  # Book cache TTL: 10 minutes
# DCS_CACHE_LOGO_TTL=3600  # Logo cache TTL: 1 hour
# DCS_CACHE_WARMUP_ENABLED=false  # Pre-fetch common data at startup (false by default)

# Rate Limiting Configuration (optional - uses defaults if not specified)
# RATE_LIMIT_ENABLED=true  # Set to false to disable rate limiting
# RATE_LIMIT_REDIS_URL=redis://redis:6379/1  # Redis DB 1 for rate limiting (separate from cache DB 0)
# RATE_LIMIT_DEFAULT=120/minute  # Default rate limit for all endpoints
